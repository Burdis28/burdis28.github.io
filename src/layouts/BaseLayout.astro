---
import '../styles/global.css';
import TopNavBar from '../components/layout/TopNavBar.astro';
import LeftSidebar from '../components/layout/LeftSidebar.astro';
import Footer from '../components/layout/Footer.astro';
import profile from '../content/data/profile.json';

interface Props {
  title: string;
  activeNav: 'home' | 'experience' | 'projects' | 'blog' | 'contact';
  description?: string;
  /** Absolute or root-relative path to the social share image. */
  ogImage?: string;
  /** Set for blog posts — switches og:type and adds BlogPosting structured data. */
  article?: {
    publishedDate: Date;
    category: string;
  };
}

const {
  title,
  activeNav,
  description = 'Ondřej Burda — backend inženýr se zaměřením na Kotlin a Javu. Portfolio, praxe a blog.',
  ogImage = '/images/og-card.jpg',
  article,
} = Astro.props;

const siteUrl = 'https://burdis28.github.io';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;

const personSchema = {
  '@type': 'Person',
  '@id': `${siteUrl}/#person`,
  name: profile.name,
  jobTitle: profile.title,
  url: siteUrl,
  image: new URL(profile.avatarUrl, siteUrl).href,
  sameAs: [profile.social.github, profile.social.linkedin],
};

const jsonLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: ogImageUrl,
      url: canonicalUrl,
      datePublished: article.publishedDate.toISOString(),
      articleSection: article.category,
      inLanguage: 'cs',
      author: personSchema,
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: `${profile.name} — portfolio`,
      url: siteUrl,
      description,
      inLanguage: 'cs',
      author: personSchema,
    };
---

<!DOCTYPE html>
<html lang="cs" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>

  <!-- SEO -->
  <meta name="description" content={description} />
  <meta name="author" content={profile.name} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Fonts — preconnect + non-blocking stylesheet links (faster than CSS @import) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" />

  <!-- Open Graph -->
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:locale" content="cs_CZ" />
  <meta property="og:site_name" content={`${profile.name} — portfolio`} />
  {article && (
    <meta property="article:published_time" content={article.publishedDate.toISOString()} />
  )}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Icons & PWA -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#3e5219" />

  <!-- Feeds & sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title={`${profile.name} — blog`} href="/rss.xml" />
</head>

<body class="bg-surface font-body text-on-surface selection:bg-primary-fixed selection:text-on-primary-fixed">

  <!-- Skip link for keyboard users -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-primary focus:text-on-primary focus:px-4 focus:py-2 focus:rounded-lg">
    Přeskočit na obsah
  </a>

  <!-- Fixed top navigation bar -->
  <TopNavBar activeNav={activeNav} />

  <!-- Fixed left sidebar (desktop only) -->
  <LeftSidebar activeNav={activeNav} />

  <!-- Content area — offset by sidebar on desktop, then centered within that space -->
  <div class="lg:ml-72">
    <main id="main-content" class="pt-20 pb-12 px-6 lg:px-16 max-w-6xl mx-auto">
      <slot />
    </main>

    <!-- Footer -->
    <Footer />
  </div>

  <!-- Mobile bottom navigation -->
  <nav class="md:hidden fixed bottom-0 left-0 w-full bg-surface-container-low/90 backdrop-blur-lg flex justify-around items-center h-16 z-50 px-4 border-t border-outline-variant/10">
    <a href="/" class={`flex flex-col items-center gap-0.5 ${activeNav === 'home' ? 'text-primary' : 'text-on-surface-variant'}`}>
      <span class="material-symbols-outlined" style={activeNav === 'home' ? 'font-variation-settings: "FILL" 1' : ''}>home</span>
      <span class="text-[10px] font-label font-bold uppercase tracking-tighter">Domů</span>
    </a>
    <a href="/experience" class={`flex flex-col items-center gap-0.5 ${activeNav === 'experience' ? 'text-primary' : 'text-on-surface-variant'}`}>
      <span class="material-symbols-outlined" style={activeNav === 'experience' ? 'font-variation-settings: "FILL" 1' : ''}>work</span>
      <span class="text-[10px] font-label font-bold uppercase tracking-tighter">Praxe</span>
    </a>
    <a href="/projects" class={`flex flex-col items-center gap-0.5 ${activeNav === 'projects' ? 'text-primary' : 'text-on-surface-variant'}`}>
      <span class="material-symbols-outlined" style={activeNav === 'projects' ? 'font-variation-settings: "FILL" 1' : ''}>terminal</span>
      <span class="text-[10px] font-label font-bold uppercase tracking-tighter">Projekty</span>
    </a>
    <a href="/blog" class={`flex flex-col items-center gap-0.5 ${activeNav === 'blog' ? 'text-primary' : 'text-on-surface-variant'}`}>
      <span class="material-symbols-outlined" style={activeNav === 'blog' ? 'font-variation-settings: "FILL" 1' : ''}>menu_book</span>
      <span class="text-[10px] font-label font-bold uppercase tracking-tighter">Blog</span>
    </a>
    <a href="/contact" class={`flex flex-col items-center gap-0.5 ${activeNav === 'contact' ? 'text-primary' : 'text-on-surface-variant'}`}>
      <span class="material-symbols-outlined" style={activeNav === 'contact' ? 'font-variation-settings: "FILL" 1' : ''}>mail</span>
      <span class="text-[10px] font-label font-bold uppercase tracking-tighter">Kontakt</span>
    </a>
  </nav>

</body>
</html>
