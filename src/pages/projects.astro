---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import SkillCategory from '../components/projects/SkillCategory.astro';
import projects from '../content/data/projects.json';
import skills from '../content/data/skills.json';

const workPrinciples = [
  {
    title: 'Stabilita především',
    description:
      'Píšu kód, který má vydržet. Sázím na čitelná a udržitelná řešení, která obstojí i za pár let.',
    icon: 'foundation',
  },
  {
    title: 'AI jako páka',
    description:
      'Agenti a automatizace mi berou rutinu, ne odpovědnost. Claude a spol. používám denně, ale výsledný kód pečlivě validuji a testuji.',
    icon: 'smart_toy',
  },
  {
    title: 'Domluva je půlka práce',
    description:
      'Technické řešení musí odpovídat tomu, co byznys opravdu potřebuje. Proto si radši dvakrát vyjasním zadání, než abych stavěl něco, co nikdo nechtěl.',
    icon: 'forum',
  },
];
---

<BaseLayout
  title="Stack | Ondřej Burda"
  activeNav="projects"
  description="Technologie, které používám denně, a způsob, jakým stavím software. Java, Kotlin, Spring a AI nástroje v každodenní praxi."
>

  <!-- Page header -->
  <header class="mb-16">
    <p class="text-tertiary font-label font-semibold tracking-widest uppercase mb-4">Čím pracuju</p>
    <h1 class="text-5xl lg:text-7xl font-headline font-bold text-on-surface leading-[1.1] mb-6">
      Stack &amp; nástroje
    </h1>
    <p class="text-on-surface-variant text-lg lg:text-xl max-w-2xl leading-relaxed">
      Technologie, které používám denně, a způsob, jakým stavím software. Není to výčet všeho, co jsem kdy viděl, jen to, na co se dá spolehnout.
    </p>
  </header>

  <!-- Skills grid -->
  <section class="mb-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {skills.map((category) => (
        <SkillCategory category={category} />
      ))}
    </div>
  </section>

  <!-- How I work -->
  <section class="mb-24">
    <div class="flex items-center gap-4 mb-12">
      <div class="h-px flex-grow bg-outline-variant opacity-20"></div>
      <h2 class="text-3xl font-headline font-semibold text-primary">Jak pracuju</h2>
      <div class="h-px w-24 bg-outline-variant opacity-20"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {workPrinciples.map((principle) => (
        <div class="bg-surface-container-low rounded-xl p-8">
          <span
            class="material-symbols-outlined text-primary text-3xl mb-4 block"
            style="font-variation-settings: 'FILL' 1"
            aria-hidden="true"
          >
            {principle.icon}
          </span>
          <h3 class="font-headline font-bold text-lg text-on-surface mb-2">
            {principle.title}
          </h3>
          <p class="text-sm text-on-surface-variant leading-relaxed">
            {principle.description}
          </p>
        </div>
      ))}
    </div>
  </section>

  <!-- Off-work projects -->
  <section class="mb-12">
    <div class="flex items-center gap-4 mb-12">
      <div class="h-px flex-grow bg-outline-variant opacity-20"></div>
      <h2 class="text-3xl font-headline font-semibold text-primary">Mimo práci</h2>
      <div class="h-px w-24 bg-outline-variant opacity-20"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

</BaseLayout>
