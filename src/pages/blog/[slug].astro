---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString('cs-CZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${post.data.title} — Ondřej Burda`}
  activeNav="blog"
  description={post.data.excerpt}
  ogImage={post.data.coverImage}
  article={{ publishedDate: post.data.date, category: post.data.category }}
>
  <article class="max-w-3xl">

    <!-- Back link -->
    <a href="/blog" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm font-medium mb-8 transition-colors">
      <span class="material-symbols-outlined" style="font-size:16px">arrow_back</span>
      Zpět na přehled
    </a>

    <!-- Cover image -->
    <div class="aspect-video rounded-xl overflow-hidden mb-8 bg-surface-container-low">
      <Image
        src={post.data.coverImage}
        alt={post.data.coverImageAlt}
        class="w-full h-full object-cover"
        width={900}
        height={506}
        loading="eager"
      />
    </div>

    <!-- Article header -->
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="px-3 py-1 bg-surface-container-high text-on-surface-variant text-xs font-bold rounded-full">
          {post.data.category}
        </span>
        <span class="text-on-surface-variant text-sm">
          {formattedDate} · {post.data.readTime} min čtení
        </span>
      </div>

      <h1 class="text-4xl md:text-5xl font-headline font-extrabold text-on-surface tracking-tight leading-tight mb-4">
        {post.data.title}
      </h1>

      <p class="text-xl text-on-surface-variant leading-relaxed">
        {post.data.excerpt}
      </p>
    </header>

    <hr class="border-outline-variant/20 mb-10" />

    <!-- Article body -->
    <div class="prose prose-slate max-w-none
      prose-headings:font-headline prose-headings:text-on-surface
      prose-p:text-on-surface-variant prose-p:leading-relaxed
      prose-a:text-primary prose-a:font-bold prose-a:no-underline hover:prose-a:underline
      prose-code:text-primary prose-code:bg-surface-container-low prose-code:rounded prose-code:px-1
      prose-pre:bg-on-primary-fixed-variant prose-pre:text-on-primary-container prose-pre:rounded-xl
      prose-strong:text-on-surface
      prose-li:text-on-surface-variant
      prose-img:rounded-xl prose-img:shadow-lg prose-img:mx-auto prose-img:my-8
      prose-figcaption:text-center prose-figcaption:text-on-surface-variant/60 prose-figcaption:text-sm prose-figcaption:mt-2
    ">
      <Content />
    </div>

    <!-- Bottom back link -->
    <div class="mt-16 pt-8 border-t border-outline-variant/15">
      <a href="/blog" class="inline-flex items-center gap-1 text-primary font-bold hover:underline transition-colors">
        <span class="material-symbols-outlined" style="font-size:16px">arrow_back</span>
        Všechny články
      </a>
    </div>

  </article>
</BaseLayout>

<!-- Lightbox modal (shared for all carousels on page) -->
<div class="blog-lightbox" id="blog-lightbox" role="dialog" aria-modal="true" aria-label="Náhled obrázku">
  <div class="blog-lightbox__inner">
    <button class="blog-lightbox__close" id="blog-lightbox-close" aria-label="Zavřít">&times;</button>
    <img class="blog-lightbox__img" id="blog-lightbox-img" src="" alt="" />
    <p class="blog-lightbox__caption" id="blog-lightbox-caption"></p>
  </div>
</div>

<script>
  // ── Lightbox ──
  const lightbox = document.getElementById('blog-lightbox')!;
  const lightboxImg = document.getElementById('blog-lightbox-img') as HTMLImageElement;
  const lightboxCaption = document.getElementById('blog-lightbox-caption')!;
  const lightboxClose = document.getElementById('blog-lightbox-close')!;

  function openLightbox(src: string, alt: string, caption: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightboxCaption.textContent = caption;
    lightbox.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  lightboxClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

  // ── Carousels ──
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('.blog-carousel__track')!;
    const slides = carousel.querySelectorAll<HTMLElement>('.blog-carousel__slide');
    const prevBtn = carousel.querySelector<HTMLButtonElement>('.blog-carousel__btn--prev')!;
    const nextBtn = carousel.querySelector<HTMLButtonElement>('.blog-carousel__btn--next')!;
    const thumbsContainer = carousel.querySelector<HTMLElement>('.blog-carousel__thumbs')!;

    let current = 0;
    const total = slides.length;

    // Build thumbnail strip + wire up lightbox on main slide images
    slides.forEach((slide, i) => {
      const srcImg = slide.querySelector('img')!;
      const figcaption = slide.querySelector('figcaption');

      // Thumbnail button
      const btn = document.createElement('button');
      btn.className = 'blog-carousel__thumb' + (i === 0 ? ' blog-carousel__thumb--active' : '');
      btn.setAttribute('aria-label', `Snímek ${i + 1}`);
      const thumbImg = document.createElement('img');
      thumbImg.src = srcImg.src;
      thumbImg.alt = srcImg.alt;
      btn.appendChild(thumbImg);
      btn.addEventListener('click', () => goTo(i));
      thumbsContainer.appendChild(btn);

      // Click on main image → lightbox
      srcImg.addEventListener('click', () => {
        openLightbox(srcImg.src, srcImg.alt, figcaption?.textContent ?? '');
      });
    });

    function goTo(index: number) {
      current = index;
      track.style.transform = `translateX(-${current * 100}%)`;

      thumbsContainer.querySelectorAll('.blog-carousel__thumb').forEach((t, i) => {
        t.classList.toggle('blog-carousel__thumb--active', i === current);
      });

      prevBtn.disabled = current === 0;
      nextBtn.disabled = current === total - 1;
    }

    prevBtn.addEventListener('click', () => { if (current > 0) goTo(current - 1); });
    nextBtn.addEventListener('click', () => { if (current < total - 1) goTo(current + 1); });

    goTo(0);
  });
</script>
