---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeaturedHighlights from "../components/home/FeaturedHighlights.astro";
import ExperiencePreview from "../components/home/ExperiencePreview.astro";
import profile from "../content/data/profile.json";
---

<BaseLayout
    title="Ondřej Burda — Backend Engineer"
    activeNav="home"
    description={profile.tagline}
>
    <!-- Intro Section: About Me -->
    <section class="mb-24">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
            <!-- Left: narrative text -->
            <div class="lg:col-span-7">
                <div
                    class="mb-4 inline-block bg-secondary-container px-3 py-1 rounded-full"
                >
                    <span
                        class="text-on-secondary-container font-label text-[10px] uppercase tracking-widest font-bold"
                        >O mně</span
                    >
                </div>
                <h1
                    class="text-5xl lg:text-7xl font-extrabold font-headline text-primary mb-8 tracking-tight leading-none"
                >
                    {profile.heroHeadline ?? "Engineering with"}
                    <br />
                    <span class="text-tertiary"
                        >{profile.heroAccent ?? "Precision."}</span
                    >
                </h1>
                <div
                    class="space-y-6 text-on-surface text-lg max-w-2xl leading-relaxed"
                >
                    <p>{profile.about}</p>
                    {
                        profile.aboutQuote && (
                            <p class="text-on-surface-variant italic border-l-4 border-tertiary/30 pl-6">
                                "{profile.aboutQuote}"
                            </p>
                        )
                    }
                </div>
            </div>

            <!-- Right: portrait + stats -->
            <div class="lg:col-span-5 relative mt-12 lg:mt-0">
                <div
                    class="aspect-square bg-surface-container-low rounded-lg relative overflow-hidden group"
                >
                    <img
                        src={profile.heroBannerUrl}
                        alt="Profile"
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                        width="500"
                        height="500"
                        onerror="this.style.display='none'"
                    />
                    <div
                        class="absolute bottom-6 -left-6 bg-surface p-6 shadow-xl max-w-[240px]"
                    >
                        <p
                            class="font-headline font-bold text-primary text-xl mb-1"
                        >
                            {profile.yearsExperience ?? "7"}+
                        </p>
                        <p
                            class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant"
                        >
                            Let v oboru
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Highlights (blog posts / projects) -->
    <FeaturedHighlights />

    <!-- Experience preview with CTA -->
    <ExperiencePreview />
</BaseLayout>
