---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;

const formattedDate = post.data.date.toLocaleDateString('cs-CZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const href = `/blog/${post.id}`;
---

<article class="md:col-span-12 group mb-8">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center bg-surface-container-low rounded-lg p-6 lg:p-12">

    <!-- Cover image — proklikatelný -->
    <a href={href} class="block overflow-hidden rounded-md aspect-video lg:aspect-square" tabindex="-1" aria-hidden="true">
      <Image
        src={post.data.coverImage}
        alt={post.data.coverImageAlt}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        width={600}
        height={600}
        loading="eager"
      />
    </a>

    <!-- Content -->
    <div class="flex flex-col justify-center">
      <div class="flex gap-3 mb-6">
        <span class="bg-surface-container-highest text-on-surface-variant px-3 py-1 rounded-sm text-[0.6875rem] font-label font-bold tracking-widest uppercase">
          Výběr redakce
        </span>
        <span class="bg-surface-container-highest text-on-surface-variant px-3 py-1 rounded-sm text-[0.6875rem] font-label font-bold tracking-widest uppercase">
          {post.data.category}
        </span>
      </div>

      <!-- Nadpis — proklikatelný -->
      <h2 class="text-3xl md:text-4xl font-bold font-headline tracking-tight text-on-surface mb-4">
        <a href={href} class="hover:text-primary transition-colors">
          {post.data.title}
        </a>
      </h2>

      <p class="text-on-surface-variant text-lg leading-relaxed mb-6 line-clamp-3">
        {post.data.excerpt}
      </p>

      <div class="flex items-center justify-between text-xs font-label uppercase tracking-widest text-on-surface-variant/60">
        <span>{post.data.readTime} min čtení · {formattedDate}</span>
        <a href={href} class="text-primary font-bold hover:underline underline-offset-4 decoration-secondary">
          Číst článek →
        </a>
      </div>
    </div>

  </div>
</article>
