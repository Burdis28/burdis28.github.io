---
const currentYear = new Date().getFullYear();
---

<footer class="w-full py-8 mt-12 bg-surface border-t border-outline-variant/15">
  <div class="max-w-7xl mx-auto px-4 md:px-6 flex flex-col md:flex-row justify-between items-center gap-4">

    <p class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant">
      © {currentYear} Ondřej Burda. Built with Astro.
    </p>

    <div class="flex gap-6">
      <a href="/contact" class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors">
        Contact
      </a>
      <a href="/blog" class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors">
        Blog
      </a>
      <a
        href="https://github.com/Burdis28/burdis28.github.io"
        target="_blank"
        rel="noopener noreferrer"
        class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors"
      >
        Source
      </a>
    </div>

  </div>
</footer>
