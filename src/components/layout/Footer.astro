  <div class="flex flex-col md:flex-row justify-between items-center gap-4 max-w-[1400px] mx-auto">
    <p class="uppercase tracking-widest">© {currentYear} Ondřej Burda · Postaveno s Astro &amp; Tailwind</p>
    <div class="flex gap-8">
      <a href="/contact" class="uppercase tracking-widest hover:text-primary transition-colors">Kontakt</a>
      <a href="/blog" class="uppercase tracking-widest hover:text-primary transition-colors">Blog</a>
    </div>
  </div>
</footer>
