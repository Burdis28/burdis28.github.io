---
import profile from '../../content/data/profile.json';
---

<div class="bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/10 shadow-editorial">
  <div class="flex flex-col items-center text-center">

    <!-- Profile photo -->
    <div class="w-32 h-32 rounded-xl overflow-hidden mb-6 border-2 border-primary-container p-1 bg-surface-container-low">
      <img
        src={profile.avatarUrl}
        alt={profile.name}
        class="w-full h-full object-cover rounded-lg"
        width="128"
        height="128"
      />
    </div>

    <!-- Name & title -->
    <h2 class="font-headline font-bold text-2xl text-on-surface">{profile.name}</h2>
    <p class="text-sm text-on-surface-variant font-medium mt-1">{profile.title}</p>

    <!-- Social links -->
    <div class="flex items-center gap-3 mt-6 mb-8">
      <a
        href={profile.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class="w-10 h-10 flex items-center justify-center rounded-xl bg-surface-container-low text-on-surface-variant hover:bg-primary hover:text-on-primary transition-all"
        aria-label="GitHub profile"
      >
        <span class="material-icons-outlined" style="font-size:20px">code</span>
      </a>
      <a
        href={profile.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="w-10 h-10 flex items-center justify-center rounded-xl bg-surface-container-low text-on-surface-variant hover:bg-primary hover:text-on-primary transition-all"
        aria-label="LinkedIn profile"
      >
        <span class="material-icons-outlined" style="font-size:20px">share</span>
      </a>
      <a
        href={profile.website.url}
        class="w-10 h-10 flex items-center justify-center rounded-xl bg-surface-container-low text-on-surface-variant hover:bg-primary hover:text-on-primary transition-all"
        aria-label="Personal website"
      >
        <span class="material-icons-outlined" style="font-size:20px">language</span>
      </a>
    </div>

    <!-- Download Resume CTA -->
    <a
      href={profile.resumeUrl}
      download
      class="w-full py-4 bg-primary text-on-primary rounded-xl font-bold text-sm tracking-wide hover:bg-primary-container transition-all shadow-lg shadow-primary/20 flex items-center justify-center gap-2"
    >
      <span class="material-icons-outlined" style="font-size:18px">download</span>
      Download Resume
    </a>

  </div>

  <!-- Tech Stack -->
  <div class="mt-10 pt-8 border-t border-outline-variant/10">
    <h3 class="font-label font-bold text-on-surface mb-4 flex items-center gap-2 uppercase tracking-widest text-[10px]">
      <span class="material-icons-outlined text-primary" style="font-size:16px">token</span>
      Tech Stack
    </h3>
    <div class="flex flex-wrap gap-2">
      {profile.techStack.map((tech) => (
        <span class="px-3 py-1.5 bg-surface-container-high rounded-xl text-[10px] font-bold text-on-surface uppercase tracking-wider">
          {tech}
        </span>
      ))}
    </div>
  </div>
</div>
