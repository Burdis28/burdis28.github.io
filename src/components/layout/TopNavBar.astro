---
import profile from '../../content/data/profile.json';

interface Props {
  activeNav: 'home' | 'experience' | 'projects' | 'blog' | 'contact';
}
const { activeNav } = Astro.props;

const navLinks = [
  { id: 'home',       label: 'Domů',     href: '/' },
  { id: 'experience', label: 'Praxe',    href: '/experience' },
  { id: 'projects',   label: 'Projekty', href: '/projects' },
  { id: 'blog',       label: 'Blog',     href: '/blog' },
  { id: 'contact',    label: 'Kontakt',  href: '/contact' },
];
---

<nav class="fixed top-0 w-full z-50 bg-surface/70 backdrop-blur-xl h-20">
  <div class="max-w-[1400px] mx-auto px-8 md:px-12 h-full flex justify-between items-center">
    <!-- Brand wordmark -->
    <a href="/" class="text-xl font-bold text-primary font-headline tracking-tight hover:opacity-80 transition-opacity">
      {profile.name}
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-8 font-headline font-semibold tracking-tight">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={
            activeNav === link.id
              ? 'text-primary border-b-2 border-primary pb-1'
              : 'text-on-surface-variant hover:text-primary transition-colors duration-300'
          }
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-on-surface-variant"
      aria-label="Otevřít menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="material-symbols-outlined">menu</span>
    </button>
  </div>
</nav>

<!-- Mobile dropdown menu -->
<div
  id="mobile-menu"
  class="hidden md:hidden fixed top-20 left-0 w-full z-40 bg-surface/95 backdrop-blur-xl border-t border-outline-variant/10"
>
  <div class="px-6 py-4 flex flex-col gap-1">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class={
          activeNav === link.id
            ? 'px-4 py-3 rounded-lg bg-primary/5 text-primary font-label text-sm font-bold'
            : 'px-4 py-3 rounded-lg text-on-surface-variant hover:bg-surface-container-low hover:text-primary transition-colors font-label text-sm font-medium'
        }
      >
        {link.label}
      </a>
    ))}
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));

    const icon = btn.querySelector('.material-symbols-outlined');
    if (icon) icon.textContent = isOpen ? 'menu' : 'close';
  });
</script>
