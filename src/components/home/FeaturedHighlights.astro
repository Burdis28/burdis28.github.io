---
import projects from '../../content/data/projects.json';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
).slice(0, 2);

const featuredProject = projects.find((p) => p.featured);
---

<!-- Featured Blog Section: Latest Insights -->
<section class="mb-24">
  <div class="flex justify-between items-end mb-12">
    <div>
      <p class="font-label text-[10px] uppercase tracking-widest text-tertiary font-bold mb-2">Ze zápisníku</p>
      <h2 class="text-3xl font-bold font-headline text-primary tracking-tight">Čerstvé z blogu</h2>
    </div>
    <a href="/blog" class="text-primary font-bold text-sm flex items-center group">
      Všechny články
      <span class="material-symbols-outlined ml-1 group-hover:translate-x-1 transition-transform">arrow_forward</span>
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {allPosts.length > 0 ? allPosts.map((post) => {
      const formattedDate = post.data.date.toLocaleDateString('cs-CZ', {
        year: 'numeric', month: 'long', day: 'numeric',
      });
      const href = `/blog/${post.id}`;
      return (
        <article class="bg-surface-container-lowest group hover:shadow-editorial transition-all flex flex-col h-full rounded-xl overflow-hidden">
          <a href={href} class="block aspect-[16/9] overflow-hidden bg-surface-container-low" tabindex="-1" aria-hidden="true">
            <Image
              src={post.data.coverImage}
              alt={post.data.coverImageAlt}
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 group-hover:scale-105"
              width={600}
              height={337}
              loading="lazy"
            />
          </a>
          <div class="p-10 flex flex-col flex-grow">
            <div class="flex items-center space-x-3 mb-4">
              <span class="font-label text-[9px] uppercase tracking-widest text-on-surface-variant px-2 py-1 bg-surface-container-high rounded-sm">{post.data.category}</span>
              <span class="text-on-surface-variant text-[11px]">{post.data.readTime} min čtení</span>
            </div>
            <h3 class="text-2xl font-bold font-headline text-on-surface mb-4 leading-tight">
              <a href={href} class="hover:text-primary transition-colors">{post.data.title}</a>
            </h3>
            <p class="text-on-surface-variant text-sm mb-8 flex-grow leading-relaxed">{post.data.excerpt}</p>
            <a
              href={href}
              class="flex items-center space-x-2 text-primary font-bold text-xs uppercase tracking-widest border-t border-surface-container-low pt-6"
            >
              <span>Číst dál</span>
              <span class="material-symbols-outlined text-sm">north_east</span>
            </a>
          </div>
        </article>
      );
    }) : (
      <!-- Fallback if no blog posts exist yet -->
      <div class="md:col-span-2 bg-surface-container-lowest p-10 rounded-xl text-center text-on-surface-variant">
        <span class="material-symbols-outlined text-4xl text-primary/20 block mb-4">edit_note</span>
        <p class="font-label text-sm">Články přibydou brzy, mezitím se podívejte na mou praxi.</p>
      </div>
    )}
  </div>
</section>
